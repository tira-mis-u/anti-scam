# Runtime
NODE_ENV=production

# Auth/JWT - tự tạo chuỗi random mạnh khi deploy production
ACCESS_TOKEN_SECRET=change-me-access-token-secret
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret

# MongoDB Atlas hoặc MongoDB server public
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/antiscam?retryWrites=true&w=majority&tls=true
MONGO_DATABASE=antiscam

# Admin bootstrap - chỉ dùng để tạo admin đầu tiên khi admin_users chưa có document nào.
# Sau khi tạo xong admin đầu tiên, nên xóa ADMIN_PASSWORD khỏi production env.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-admin-password
ENABLE_ADMIN_UI=true
ENABLE_ADMIN_API=true
# Tùy chọn: chỉ cho các IP này truy cập /admin và /api/admin. Để trống nếu IP thay đổi thường xuyên.
# ADMIN_ALLOWED_IPS=1.2.3.4,5.6.7.8
ADMIN_SESSION_TTL_MS=28800000
# ADMIN_COOKIE_SECURE=true
