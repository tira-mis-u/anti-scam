{
  "name": "AntiScam",
  "version": "1.7.0",
  "description": "Bảo vệ bạn khỏi các trang web lừa đảo, mã độc và ăn cắp thông tin.",
  "homepage_url": "https://antiscam.vn/",
  "permissions": [
    "tabs",
    "storage",
    "webRequest",
    "notifications",
    "declarativeNetRequest",
    "downloads",
    "geolocation"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "scripts/background/background.js"
  },
  "action": {
    "default_popup": "pages/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "scripts/vendor/jquery.js",
        "scripts/shared/features.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "scripts/ui/blocking.js",
        "scripts/content/page_hooks.js",
        "scripts/content/network_hooks.js",
        "pages/blocking/index.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "incognito": "split",
  "icons": {
    "16": "assets/antiScamLogo.png",
    "32": "assets/antiScamLogo.png",
    "48": "assets/antiScamLogo.png",
    "128": "assets/antiScamLogo.png"
  },
  "manifest_version": 3
}
