# Local/private config overrides - keep default/production config committed
backend/config/local.json
backend/config/local-*.json
backend/config/*local*.json

# Runtime uploaded report evidence - generated by backend, do not commit user uploads
backend/public/report-screenshots/

# Hosting/tooling local folders
.vercel/
.netlify/
.render/
.railway/

# OS metadata and temporary files
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes
desktop.ini
$RECYCLE.BIN/
*.tmp
*.temp

# IDE and Editor settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Diagnostic/linter configurations
.eslintcache
.stylelintcache
.parcel-cache
.tsbuildinfo

# Generated mirrors of packages/*.js (regenerated by `npm run sync:shared`)
apps/extension/scripts/shared/
apps/mobile/src/shared/
