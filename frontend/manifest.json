{
  "name": "AntiScam",
  "version": "1.7.0",
  "description": "Bảo vệ bạn khỏi các trang web lừa đảo, mã độc và ăn cắp thông tin.",
  "homepage_url": "https://antiscam.vn/",
  "permissions": [
    "tabs",
    "storage",
    "webRequest",
    "notifications",
    "declarativeNetRequest",
    "downloads"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "plugin_ui.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "js/jquery.js",
        "js/features.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "js/blocking.js",
        "js/page_hooks.js",
        "blocking.html",
        "js/network_hooks.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "incognito": "split",
  "icons": {
    "16": "assets/antiScamLogo.png",
    "32": "assets/antiScamLogo.png",
    "48": "assets/antiScamLogo.png",
    "128": "assets/antiScamLogo.png"
  },
  "manifest_version": 3,
  "optional_permissions": [
    "geolocation"
  ]
}