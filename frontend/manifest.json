{
  "name": "AntiScam",
  "version": "1.0.3",
  "description": "Tiện ích giúp bảo vệ bạn khỏi các trang web có nguy cơ lừa đảo, giả mạo, có nội dung xấu hoặc phần mềm độc hại.",
  "homepage_url": "https://chongluadao.vn/",
  "permissions": [
    "tabs",
    "storage",
    "webRequest",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "plugin_ui.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "js/jquery.js",
        "js/psl.min.js",
        "js/engines/url-intelligence.js",
        "js/engines/brand-detection.js",
        "js/engines/website-intelligence.js",
        "js/features.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["js/blocking.js", "blocking.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "incognito": "split",
  "icons": {
    "16": "assets/antiScamLogo.png",
    "32": "assets/antiScamLogo.png",
    "48": "assets/antiScamLogo.png",
    "128": "assets/antiScamLogo.png"
  },
  "manifest_version": 3
}
