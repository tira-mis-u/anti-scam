# Runtime
NODE_ENV=production

# Auth/JWT - tự tạo chuỗi random mạnh khi deploy production
ACCESS_TOKEN_SECRET=change-me-access-token-secret
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret

# MongoDB Atlas hoặc MongoDB server public
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/antiscam?retryWrites=true&w=majority
MONGO_DATABASE=antiscam
